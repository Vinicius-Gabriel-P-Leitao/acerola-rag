{
	"svelte.enable-ts-plugin": true,
	"editor.formatOnSave": true,
	"[svelte]": {
		"editor.defaultFormatter": "svelte.svelte-vscode"
	},
	"files.associations": {
		"*.css": "tailwindcss"
	},
	"files.exclude": {
		"**/node_modules/": true,
		"**/.svelte-kit": true
	},
	"search.exclude": {
		"**/node_modules/": true,
		"**/.svelte-kit": true
	}
}
