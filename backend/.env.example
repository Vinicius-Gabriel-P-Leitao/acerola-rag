# ── LLM Provider ─────────────────────────────────────────────────────────────
LLM_PROVIDER=gemini
LLM_MODEL=gemini-3-flash-preview
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# ── Chaves por provider (preencha só a do provider que vai usar) ───────────────
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=asd...
ANTHROPIC_API_KEY=sk-ant-...

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBED_DIM=384
EMBED_MODEL=BAAI/bge-small-en-v1.5

# ── Vector store: faiss | qdrant ──────────────────────────────────────────────
QDRANT_PORT=6333
VECTOR_STORE=qdrant
QDRANT_HOST=127.0.0.1
PERSIST_DIR=./data/index
UPLOAD_DIR=./data/uploads
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=8000
API_HOST=0.0.0.0

# ── Langfuse (remova ou deixe as chaves em branco para desabilitar) ───────────
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── Configuração para permitir coisas que só pode existir em dev mode ─────────
DEBUG=true