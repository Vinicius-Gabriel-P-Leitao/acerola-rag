# ── LLM Provider ─────────────────────────────────────────────────────────────
# Escolha o provider: openai | ollama | gemini | claude
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# ── Chaves por provider (preencha só a do provider que vai usar) ───────────────
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
ANTHROPIC_API_KEY=sk-ant-...

# ── Ollama (local, sem chave) ─────────────────────────────────────────────────
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434/v1

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBED_MODEL=BAAI/bge-small-en-v1.5
EMBED_DIM=384

# ── Vector store: faiss | chroma ──────────────────────────────────────────────
VECTOR_STORE=chroma
CHROMA_HOST=localhost
CHROMA_PORT=8001
PERSIST_DIR=./data/index
UPLOAD_DIR=./data/uploads
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_URL=http://localhost:8000/api/v1

# ── Langfuse (deixe em branco para desabilitar) ───────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
